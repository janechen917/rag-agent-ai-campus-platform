SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# AI功能配置 - 选择一种方式
# ============================================

# 方式1: 使用GitHub Models (推荐，免费)
# 1. 访问 https://github.com/settings/tokens 创建Personal Access Token
# 2. 勾选 'repo' 和 'read:user' 权限
# 3. 将token填入下方OPENAI_API_KEY
USE_GITHUB_MODELS=True
OPENAI_API_BASE=https://models.inference.ai.azure.com
OPENAI_API_KEY=ghp_your_github_personal_access_token_here
AI_MODEL_NAME=gpt-4o-mini

# 方式2: 使用OpenAI API (需付费)
# USE_GITHUB_MODELS=False
# OPENAI_API_KEY=sk-your-openai-api-key-here
# AI_MODEL_NAME=gpt-3.5-turbo

# 可用的GitHub Models:
# - gpt-4o (最强大)
# - gpt-4o-mini (推荐，快速且免费)
# - meta-llama-3.1-405b-instruct
# - meta-llama-3.1-70b-instruct
# - mistral-large-2407
# ============================================

# 数据库配置(可选，默认使用SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ai_learning_db
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432
