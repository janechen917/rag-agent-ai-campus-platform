{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": [
    {
      "key": "VITE_API_BASE_URL",
      "description": "Backend API Base URL (e.g., https://your-backend-domain.com/api)"
    },
    {
      "key": "VITE_WS_URL",
      "description": "WebSocket URL for chat (e.g., wss://your-backend-domain.com/ws/chat/)"
    }
  ]
}
